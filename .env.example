# Supabase — créer un projet sur https://supabase.com/dashboard
# Puis copier ce fichier en .env.local et remplir les valeurs.
# Settings → API → Project URL + Publishable key (sb_publishable_...)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-key-here
